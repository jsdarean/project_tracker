{
  "name": "project-extractor-backend",
  "version": "1.0.0",
  "description": "本地后端服务：接收 Chrome 插件提取的项目信息并写入 MySQL",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "node --watch server.js",
    "setup": "node setup.js",
    "init-db": "node -e \"require('./db').initDatabase().then(()=>process.exit(0)).catch(()=>process.exit(1))\"",
    "test-extractor": "node test-extractor.js"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.2",
    "mysql2": "^3.11.5",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "puppeteer": "^25.3.0"
  }
}

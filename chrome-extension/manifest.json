{
  "manifest_version": 3,
  "name": "项目信息一键提取",
  "version": "1.0.0",
  "description": "从网页提取立项批复正文并结构化保存到本地 MySQL 数据库",
  "permissions": [
    "activeTab",
    "contextMenus",
    "downloads",
    "scripting",
    "sidePanel",
    "storage"
  ],
  "host_permissions": [
    "http://localhost:3000/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_title": "项目信息一键提取",
    "default_popup": "popup.html"
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
